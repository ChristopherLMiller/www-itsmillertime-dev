{
	"name": "www-itsmillertime-dev",
	"private": true,
	"version": "0.15.0",
	"type": "module",
	"scripts": {
		"dev": "pnpm run fetch-payload-types && vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"fetch-payload-types": "tsx scripts/sync-payload-types.ts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test": "vitest run --project=unit",
		"test:watch": "vitest --project=unit",
		"test:storybook": "vitest run --project=storybook",
		"test:coverage": "vitest run --project=unit --coverage"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@eslint/compat": "^2.0.0",
		"@eslint/js": "^9.39.2",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-svelte-csf": "^5.1.1",
		"@storybook/addon-vitest": "^10.3.3",
		"@storybook/sveltekit": "^10.3.3",
		"@sveltejs/adapter-node": "^5.4.0",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@vitest/browser-playwright": "^4.1.2",
		"@vitest/coverage-v8": "^4.1.2",
		"dotenv": "^17.2.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.3.3",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^17.0.0",
		"playwright": "^1.58.2",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"storybook": "^10.3.3",
		"stylelint": "^16.26.1",
		"stylelint-config-standard": "^39.0.1",
		"stylelint-declaration-strict-value": "^1.10.11",
		"svelte": "^5.46.1",
		"svelte-bricks": "^0.4.1",
		"svelte-check": "^4.3.5",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.51.0",
		"vite": "^7.3.0",
		"vitest": "^4.1.2"
	},
	"packageManager": "pnpm@10.27.0",
	"dependencies": {
		"@better-auth/passkey": "^1.4.19",
		"@fortawesome/fontawesome-free": "^7.1.0",
		"@js-temporal/polyfill": "^0.5.1",
		"@payloadcms/sdk": "^3.69.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@upstash/redis": "^1.36.0",
		"better-auth": "^1.4.19",
		"highlight.js": "^11.11.1",
		"maplibre-gl": "^5.16.0",
		"media-chrome": "^4.17.2",
		"nodejs": "link:@upstash/redis/nodejs",
		"qs-esm": "^7.0.3",
		"satori": "^0.19.1",
		"satori-html": "^0.3.2",
		"sharp": "^0.34.5",
		"video.js": "^8.23.4",
		"videojs-youtube": "^3.0.1"
	}
